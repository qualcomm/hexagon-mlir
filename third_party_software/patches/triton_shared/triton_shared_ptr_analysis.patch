+/// Local patch to QC.
+LogicalResult PtrAnalysis::visitOperandMinSI(arith::MinSIOp minOp,
+                                             PtrState &state,
+                                             const Location loc,
+                                             OpBuilder &builder) {
+  assert(state.isEmpty());
+
+  // For min/max operations used in bounds clamping (e.g., tl.minimum(indices, max_val)),
+  // we want to propagate the state from the operand that contains the actual indices.
+  // Typically, one operand is a constant or scalar bound, and the other is the tensor of indices.
+
+  PtrState lhsState;
+  if (visitOperand(minOp.getLhs(), lhsState, loc, builder).failed()) {
+    return failure();
+  }
+
+  PtrState rhsState;
+  if (visitOperand(minOp.getRhs(), rhsState, loc, builder).failed()) {
+    return failure();
+  }
+
+  // If one operand is a scalar and the other is a tensor, use the tensor's state
+  if (lhsState.scalar && !rhsState.scalar && rhsState.getRank() > 0) {
+    state = rhsState;
+    return success();
+  } else if (rhsState.scalar && !lhsState.scalar && lhsState.getRank() > 0) {
+    state = lhsState;
+    return success();
+  }
+
+  // If both are tensors or both are scalars, prefer the one that's not structured
+  // (for gather/scatter patterns) or just use lhs as default
+  if (!lhsState.isStructured() && rhsState.isStructured()) {
+    state = lhsState;
+  } else if (lhsState.isStructured() && !rhsState.isStructured()) {
+    state = rhsState;
+  } else {
+    // Default: use lhs state
+    state = lhsState;
+  }
+
+  return success();
+}
