// RUN: linalg-hexagon-opt -pass-pipeline='builtin.module(func.func(conv-tiling\
// RUN: {conv-tile-sizes="1:8"}))' %s | FileCheck %s --check-prefix=HEIGHT
// RUN: linalg-hexagon-opt -pass-pipeline='builtin.module(func.func(conv-tiling\
// RUN: {conv-tile-sizes="3:32"}))' %s | FileCheck %s --check-prefix=OC
// RUN: linalg-hexagon-opt -pass-pipeline='builtin.module(func.func(conv-tiling\
// RUN: {conv-tile-sizes="1:8,3:32"}))' %s | FileCheck %s --check-prefix=MULTI

module {
  func.func @main(%arg0: tensor<1x239x27x128xf16>, %arg1: tensor<64x1x1x128xf16>) -> tensor<1x239x27x64xf16> {
    %0 = tensor.empty() : tensor<1x239x27x64xf16>
    %cst = arith.constant 0.000000e+00 : f16
    %1 = tensor.empty() : tensor<1x30x7x4x8x4x32xf16>
    %pack = linalg.pack %arg0 padding_value(%cst : f16) inner_dims_pos = [1, 2, 3]
            inner_tiles = [8, 4, 32] into %1 :
            tensor<1x239x27x128xf16> -> tensor<1x30x7x4x8x4x32xf16>
    %2 = tensor.empty() : tensor<1x30x7x4x8x2x32x2xf16>
    %pack_0 = linalg.pack %pack inner_dims_pos = [5] inner_tiles = [2] into %2 :
              tensor<1x30x7x4x8x4x32xf16> -> tensor<1x30x7x4x8x2x32x2xf16>
    %3 = builtin.unrealized_conversion_cast %pack_0 : tensor<1x30x7x4x8x2x32x2xf16>
         to tensor<1x239x27x128xf16>
    %padded = tensor.pad %arg1 low[0, 0, 0, 0] high[0, 0, 0, 0] {
    ^bb0(%arg2: index, %arg3: index, %arg4: index, %arg5: index):
      tensor.yield %cst : f16
    } : tensor<64x1x1x128xf16> to tensor<64x1x1x128xf16>
    %c2 = arith.constant 2 : index
    %c32 = arith.constant 32 : index
    %c1 = arith.constant 1 : index
    %c1_1 = arith.constant 1 : index
    %c4 = arith.constant 4 : index
    %c16 = arith.constant 16 : index
    %c2_2 = arith.constant 2 : index
    %from_elements = tensor.from_elements %c2, %c32, %c1, %c1_1, %c4, %c16, %c2_2 : tensor<7xindex>
    %reshape = tensor.reshape %padded(%from_elements) :
               (tensor<64x1x1x128xf16>, tensor<7xindex>) -> tensor<2x32x1x1x4x16x2xf16>
    %4 = tensor.empty() : tensor<2x4x1x1x16x32x2xf16>
    %transposed = linalg.transpose ins(%reshape : tensor<2x32x1x1x4x16x2xf16>)
                  outs(%4 : tensor<2x4x1x1x16x32x2xf16>)
                  permutation = [0, 4, 2, 3, 5, 1, 6]
    %5 = builtin.unrealized_conversion_cast %transposed : tensor<2x4x1x1x16x32x2xf16>
         to tensor<64x1x1x128xf16>
    %6 = tensor.empty() : tensor<1x239x27x64xf16>
    %7 = linalg.conv_2d_nhwc_fhwc
         ins(%3, %5 : tensor<1x239x27x128xf16>, tensor<64x1x1x128xf16>)
         outs(%6 : tensor<1x239x27x64xf16>) -> tensor<1x239x27x64xf16>
    %8 = builtin.unrealized_conversion_cast %7 : tensor<1x239x27x64xf16>
         to tensor<1x30x7x2x8x2x32x2xf16>
    %9 = tensor.empty() : tensor<1x30x7x2x8x4x32xf16>
    %unpack = linalg.unpack %8 inner_dims_pos = [5] inner_tiles = [2] into
              %9 : tensor<1x30x7x2x8x2x32x2xf16> -> tensor<1x30x7x2x8x4x32xf16>
    %10 = tensor.empty() : tensor<1x239x27x64xf16>
    %unpack_3 = linalg.unpack %unpack inner_dims_pos = [1, 2, 3] inner_tiles = [8, 4, 32]
                into %10 : tensor<1x30x7x2x8x4x32xf16> -> tensor<1x239x27x64xf16>
    return %unpack_3 : tensor<1x239x27x64xf16>
  }
}

