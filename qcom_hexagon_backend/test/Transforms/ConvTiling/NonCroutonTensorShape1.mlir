// HEIGHT-SAME:      tensor<2x4x1x1x16x32x2xf16> to tensor<64x1x1x128xf16>

// HEIGHT:           %[[COMP_RES_TENSOR:.*]] = scf.for %[[IDX_0:.*]] = %c0 to %c232
// HEIGHT-SAME:      step %c8 iter_args(%[[RES_TENSOR:.*]] = %[[EMPTY_TENSOR:.*]]) ->
// HEIGHT-SAME:      (tensor<1x239x27x64xf16>) {

// HEIGHT-NEXT:        %[[INPUT_SLICE:.*]] = tensor.extract_slice
// HEIGHT-SAME:        %[[INPUT_TENSOR]][0, %[[IDX_0]], 0, 0] [1, 8, 27, 128] [1, 1, 1, 1] :
// HEIGHT-SAME:        tensor<1x239x27x128xf16> to tensor<1x8x27x128xf16>

// HEIGHT-NEXT:        %[[RES_SLICE:.*]] = tensor.extract_slice
// HEIGHT-SAME:        %[[RES_TENSOR]][0, %[[IDX_0]], 0, 0] [1, 8, 27, 64] [1, 1, 1, 1] :
// HEIGHT-SAME:        tensor<1x239x27x64xf16> to tensor<1x8x27x64xf16>

// HEIGHT-NEXT:        %[[CONV_RES:.*]] = linalg.conv_2d_nhwc_fhwc
// HEIGHT-SAME:        ins(%[[INPUT_SLICE]], %[[FILTER]] :
// HEIGHT-SAME:        tensor<1x8x27x128xf16>, tensor<64x1x1x128xf16>)
// HEIGHT-SAME:        outs(%[[RES_SLICE]] : tensor<1x8x27x64xf16>) -> tensor<1x8x27x64xf16>

// HEIGHT-NEXT:        %[[INSERT_SLICE:.*]] = tensor.insert_slice %[[CONV_RES]] into
// HEIGHT-SAME:        %[[RES_TENSOR]][0, %[[IDX_0]], 0, 0] [1, 8, 27, 64] [1, 1, 1, 1] :
// HEIGHT-SAME:        tensor<1x8x27x64xf16> into tensor<1x239x27x64xf16>

// HEIGHT-NEXT:        scf.yield %[[INSERT_SLICE]] : tensor<1x239x27x64xf16>
// HEIGHT-NEXT:      }

// HEIGHT-NEXT:      %[[INVERSE_PACK:.*]] = builtin.unrealized_conversion_cast
// HEIGHT-SAME:      %[[COMP_RES_TENSOR]] :
// HEIGHT-SAME:      tensor<1x239x27x64xf16> to tensor<1x30x7x2x8x2x32x2xf16>

// HEIGHT-NEXT:      %[[INVERSE_UNPACK:.*]] = builtin.unrealized_conversion_cast
// HEIGHT-SAME:      %[[INVERSE_PACK]] :
// HEIGHT-SAME:      tensor<1x30x7x2x8x2x32x2xf16> to tensor<1x239x27x64xf16>

// HEIGHT-NEXT:      %[[INPUT_SLICE_PEELED:.*]] = tensor.extract_slice
// HEIGHT-SAME:      %[[INPUT_TENSOR]][0, 232, 0, 0] [1, 7, 27, 128] [1, 1, 1, 1] :
// HEIGHT-SAME:      tensor<1x239x27x128xf16> to tensor<1x7x27x128xf16>

// HEIGHT-NEXT:      %[[RES_SLICE_PEELED:.*]] = tensor.extract_slice
// HEIGHT-SAME:      %[[INVERSE_UNPACK]][0, 232, 0, 0] [1, 7, 27, 64] [1, 1, 1, 1] :
// HEIGHT-SAME:      tensor<1x239x27x64xf16> to tensor<1x7x27x64xf16>

// HEIGHT-NEXT:      %[[CONV_RES_PEELED:.*]] = linalg.conv_2d_nhwc_fhwc
// HEIGHT-SAME:      ins(%[[INPUT_SLICE_PEELED]], %[[FILTER]] :
// HEIGHT-SAME:      tensor<1x7x27x128xf16>, tensor<64x1x1x128xf16>)
// HEIGHT-SAME:      outs(%[[RES_SLICE_PEELED]] : tensor<1x7x27x64xf16>) -> tensor<1x7x27x64xf16>

// HEIGHT-NEXT:      %[[CONV_RES_SLICE_PEELED:.*]] = tensor.insert_slice
// HEIGHT-SAME:      %[[CONV_RES_PEELED]] into
// HEIGHT-SAME:      %[[INVERSE_UNPACK]][0, 232, 0, 0] [1, 7, 27, 64] [1, 1, 1, 1] :
// HEIGHT-SAME:      tensor<1x7x27x64xf16> into tensor<1x239x27x64xf16>

// HEIGHT-NEXT:      %[[PACK:.*]] = builtin.unrealized_conversion_cast
